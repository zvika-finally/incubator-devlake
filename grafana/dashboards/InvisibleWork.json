            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "total_reviewer_minutes"
          }
        ]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": "mysql",
          "editorMode": "code",
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "SELECT\n  engineer_id,\n  SUM(reviewer_minutes) AS total_reviewer_minutes,\n  SUM(author_minutes)   AS total_author_minutes,\n  ROUND(SUM(reviewer_minutes) * 1.0 / NULLIF(SUM(author_minutes), 0), 2) AS combined_ratio\nFROM engineer_verification_effort\nWHERE period_week >= $__timeFrom() AND period_week < $__timeTo()\nGROUP BY engineer_id\nHAVING SUM(reviewer_minutes) > 0\nORDER BY total_reviewer_minutes DESC\nLIMIT 20",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
              }
            ]
          ],
          "where": []
        }
      ],
