          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "SELECT\n  pr.title,\n  u.name AS engineer,\n  pr.merged_date,\n  c.ai_cohort,\n  comp.batch_bucket,\n  (COALESCE(d.has_revert14d,0) + COALESCE(d.has_hotfix14d,0)) AS defect_signals,\n  pr.url\nFROM pull_requests pr\nJOIN pr_ai_cohort c ON c.pr_id = pr.id\nJOIN pr_change_composition comp ON comp.pr_id = pr.id\nLEFT JOIN pr_defect_signals d ON d.pr_id = pr.id AND d.window_close_date <= NOW()\nLEFT JOIN user_accounts ua ON ua.account_id = pr.author_id\nLEFT JOIN users u ON u.id = ua.user_id\nWHERE pr.merged_date >= $__timeFrom() AND pr.merged_date < $__timeTo()\n  AND c.ai_cohort = 'HIGH'\n  AND ((d.has_revert14d = 1 OR d.has_hotfix14d = 1) OR comp.batch_bucket = 'XL')\nORDER BY pr.merged_date DESC\nLIMIT 25",
          "refId": "A",
