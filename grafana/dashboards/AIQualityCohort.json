        {
          "datasource": "mysql",
          "editorMode": "code",
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "SELECT\n  DATE_ADD(DATE(pr.merged_date), INTERVAL -WEEKDAY(pr.merged_date) DAY) AS time,\n  c.ai_cohort,\n  AVG(CASE WHEN (d.has_revert14d = 1 OR d.has_hotfix14d = 1) THEN 1.0 ELSE 0.0 END) * 100 AS revert_hotfix_rate_pct\nFROM pull_requests pr\nJOIN pr_ai_cohort c ON c.pr_id = pr.id\nJOIN pr_defect_signals d ON d.pr_id = pr.id AND d.window_close_date <= NOW()\nWHERE pr.merged_date >= $__timeFrom() AND pr.merged_date < $__timeTo()\n  AND pr.author_id <> '' AND pr.author_id IS NOT NULL\n  AND pr.author_name NOT REGEXP '\\\\[bot\\\\]|dependabot|argocd|github-actions|cursoragent'\nGROUP BY DATE_ADD(DATE(pr.merged_date), INTERVAL -WEEKDAY(pr.merged_date) DAY), c.ai_cohort\nORDER BY time",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
              }
            ]
          ],
          "timeColumn": "time",
          "where": []
        }
      ],
