          "rawSql": "SELECT\n  DATE_ADD(DATE(pr.merged_date), INTERVAL -WEEKDAY(pr.merged_date) DAY) AS time,\n  c.ai_cohort,\n  AVG(comp.refactor_ratio) AS avg_refactor_ratio\nFROM pull_requests pr\nJOIN pr_ai_cohort c ON c.pr_id = pr.id\nJOIN pr_change_composition comp ON comp.pr_id = pr.id\nWHERE pr.merged_date >= $__timeFrom() AND pr.merged_date < $__timeTo()\nGROUP BY DATE_ADD(DATE(pr.merged_date), INTERVAL -WEEKDAY(pr.merged_date) DAY), c.ai_cohort\nORDER BY time",
