      "targets": [
        {
          "datasource": "mysql",
          "editorMode": "code",
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "queryType": "randomWalk",
          "rawQuery": true,
          "rawSql": "SELECT\n  u.name AS engineer,\n  COUNT(*) AS total_prs,\n  SUM(CASE WHEN (d.has_revert14d = 1 OR d.has_hotfix14d = 1) THEN 1 ELSE 0 END) AS prs_with_defect,\n  ROUND(SUM(CASE WHEN (d.has_revert14d = 1 OR d.has_hotfix14d = 1) THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 2) AS defect_rate_pct\nFROM pull_requests pr\nJOIN user_accounts ua ON ua.account_id = pr.author_id\nJOIN users u ON u.id = ua.user_id\nJOIN pr_defect_signals d ON d.pr_id = pr.id AND d.window_close_date <= NOW()\nWHERE pr.merged_date >= $__timeFrom() AND pr.merged_date < $__timeTo()\n  AND u.name NOT IN ('dependabot[bot]','claude','claude[bot]','github-actions[bot]','cursoragent','argocd-image-updater')\nGROUP BY u.id, u.name\nHAVING COUNT(*) >= 5\nORDER BY defect_rate_pct DESC, total_prs DESC\nLIMIT 20",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "value"
                ],
                "type": "column"
